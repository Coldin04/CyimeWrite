# =========================
# Cyime 服务端环境变量示例
# 复制为 packages/server/.env 后按需修改。
# 未列出的变量一般代表当前开发环境下可使用默认值。
# =========================

# ---- Global / 全局设置 ----
# 环境设置，默认 production
ENV=production

# ---- 认证 / 会话 ----
# Access Token 与媒体签名等默认都会依赖这把密钥。
JWT_SECRET_KEY=replace-with-a-strong-secret

# APP_ENCRYPTION_KEY encrypts stored OAuth client secrets and API tokens.
# Leave empty to fall back to JWT_SECRET_KEY, or set a distinct random value (for example: openssl rand -hex 32).
APP_ENCRYPTION_KEY=

# Access Token 生命周期（分钟），默认 15
ACCESS_TOKEN_LIFETIME_MINUTES=15

# Refresh Token 生命周期（小时），默认 720（30 天）
REFRESH_TOKEN_LIFETIME_HOURS=720

# 登录成功后前端回调地址
FRONTEND_CALLBACK_URL=http://localhost:5173/auth/callback

# 对外可访问的后端基础地址，用于拼接登录入口和 OIDC 回调地址
API_BASE_URL=http://localhost:8080


# ---- 跨域 ----
# 服务监听端口，默认 8080
PORT=8080

# 多个来源用英文逗号分隔；本地开发默认允许 http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173


# ---- 文档数量限制 ----
# 全局默认文档上限。
# 留空表示默认不限制；用户如果单独配置了 document_quota，会优先使用用户自己的值。
DEFAULT_DOCUMENT_QUOTA=


# ---- 调试 / 初始化 ----
# 启动时重置工作区业务表，仅调试时使用
RESET_WORKSPACE_TABLES_ON_BOOT=false

# 协作共享开发绕过开关（仅本地联调）
# true 时跳过 SMTP 与邮箱验证门槛，便于测试邀请流程；生产必须为 false。
SHARING_DEV_BYPASS=false

# 是否开启实时协作。
# 这是主开关。
# - packages/server 会通过 /api/v1/config 把 collaborationEnabled 下发给前端
# - packages/realtime 会据此决定是否接受 websocket / presence / persist-now 请求
# 如果要完全关闭协作，请在 packages/server/.env 和 packages/realtime/.env 中都设置为 false。
# 如果本实例不使用协作，建议直接不启动 packages/realtime 服务。
COLLABORATION_ENABLED=true

# 前端本地附加开关，默认 true。
# 仅当你希望某个 packages/web 部署固定保持单人模式时再设置为 false。
# 前端最终是否启用协作能力 = PUBLIC_COLLABORATION_ENABLED && 后端 /api/v1/config 的 collaborationEnabled
# 该值属于 packages/web/.env，但统一在这里记录，避免分散查找。
# 如果已关闭 COLLABORATION_ENABLED，建议这里也同步设为 false。
PUBLIC_COLLABORATION_ENABLED=true


# ---- 媒体签名 ----
# 私有媒体访问签名密钥；留空时会回退到 JWT_SECRET_KEY
MEDIA_TOKEN_SECRET=

# 私有媒体短期签名有效期（秒），默认 120
MEDIA_SIGN_TTL_SECONDS=120

# 资产批量 resolve 签名有效期（秒）；未设置时回退到 MEDIA_SIGN_TTL_SECONDS
MEDIA_ASSET_RESOLVE_TTL_SECONDS=120

# 私有头像短期签名有效期（秒），默认 300
MEDIA_AVATAR_SIGN_TTL_SECONDS=300


# ---- 头像上传 ----
# 头像最大字节数，默认 2097152（2MB）
MEDIA_AVATAR_MAX_BYTES=2097152

# ---- 文档图片上传 ----
# 文档编辑器内图片上传最大字节数，默认 5242880（5MB）
MEDIA_DOCUMENT_IMAGE_MAX_BYTES=5242880


# ---- 媒体存储 ----
# 可选: local | r2 | s3 | cos
MEDIA_STORAGE_PROVIDER=local

# 本地存储模式
MEDIA_LOCAL_ROOT_DIR=/tmp/cyimewrite-media
MEDIA_LOCAL_BASE_URL=/media-files

# S3 / R2 / COS 通用配置
MEDIA_S3_ENDPOINT=
MEDIA_S3_BUCKET=
MEDIA_S3_REGION=auto
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
MEDIA_S3_PUBLIC_BASE_URL=

# R2 同义变量（兼容旧配置）
R2_ENDPOINT=
R2_BUCKET=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=


# ---- 媒体 GC / 引用回收 ----
# 是否开启删除 worker，默认 true
MEDIA_ASSET_GC_ENABLED=true

# 轮询间隔，支持 Go duration，例如 1m / 30s
MEDIA_ASSET_GC_INTERVAL=1m

# 每轮删除任务处理数量，默认 20
MEDIA_ASSET_GC_BATCH_SIZE=20

# 删除任务最大重试次数，默认 5
MEDIA_ASSET_GC_MAX_ATTEMPTS=5

# 删除失败后的重试间隔，支持 Go duration，例如 5m
MEDIA_ASSET_GC_RETRY_GAP=5m

# 物理 blob 删除延迟，支持 Go duration，例如 24h / 12h
MEDIA_BLOB_DELETE_DELAY=24h

# 是否开启引用关系对账，默认 true
MEDIA_ASSET_RECONCILE_ENABLED=true

# 引用关系对账间隔，支持 Go duration，例如 24h / 12h
MEDIA_ASSET_RECONCILE_INTERVAL=24h

# 缩略图补齐间隔，支持 Go duration，例如 1h / 2h
MEDIA_THUMBNAIL_RECONCILE_INTERVAL=1h

# 每轮引用对账 / 缩略图补齐处理数量，默认 200
MEDIA_ASSET_RECONCILE_BATCH_SIZE=200
