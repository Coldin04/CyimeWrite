{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"packageManager": "pnpm@10.11.1",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "node ./scripts/build-target.mjs",
		"build:cloudflare": "node ./scripts/build-target.mjs cloudflare",
		"build:edgeone": "node ./scripts/build-target.mjs edgeone",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"machine-translate": "inlang machine translate --project project.inlang",
		"lint": "eslint . --ext .ts,.svelte",
		"lint:fix": "eslint . --ext .ts,.svelte --fix",
		"paraglide": "pnpm paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy custom-manual-cookie preferredLanguage baseLocale",
		"paraglide:preview": "cp src/locales/en.json src/locales/en.json.bak && cp src/locales/zh.json src/locales/en.json && pnpm paraglide && mv src/locales/en.json.bak src/locales/en.json"
	},
	"devDependencies": {
		"@edgeone/sveltekit": "^1.1.0",
		"@iconify-json/ph": "^1.2.2",
		"@inlang/cli": "^3.1.9",
		"@inlang/paraglide-js": "^2.15.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@types/node": "^25.3.5",
		"autoprefixer": "^10.4.27",
		"prosemirror-model": "^1.25.4",
		"prosemirror-view": "^1.41.6",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.9.3",
		"unplugin-icons": "^23.0.1",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@hocuspocus/provider": "^3.4.4",
		"@tiptap/core": "^3.20.4",
		"@tiptap/extension-code-block-lowlight": "3.21.0",
		"@tiptap/extension-collaboration": "^3.21.0",
		"@tiptap/extension-collaboration-cursor": "3.0.0-next.6",
		"@tiptap/extension-image": "^3.20.4",
		"@tiptap/extension-link": "^3.20.4",
		"@tiptap/extension-mathematics": "^3.21.0",
		"@tiptap/extension-placeholder": "^3.20.4",
		"@tiptap/extension-table": "^3.20.4",
		"@tiptap/extension-table-cell": "^3.20.4",
		"@tiptap/extension-table-header": "^3.20.4",
		"@tiptap/extension-table-row": "^3.20.4",
		"@tiptap/pm": "^3.20.4",
		"@tiptap/starter-kit": "^3.20.4",
		"@tiptap/y-tiptap": "^3.0.2",
		"katex": "^0.16.44",
		"lowlight": "^3.3.0",
		"marked": "^17.0.4",
		"mermaid": "^11.15.0",
		"svelte-easy-crop": "^5.0.0",
		"svelte-sonner": "^1.0.8",
		"y-protocols": "^1.0.7",
		"yjs": "^13.6.30"
	},
	"pnpm": {
		"overrides": {
			"@tiptap/extension-collaboration-cursor": "3.0.0-next.6",
			"kysely": ">=0.28.14",
			"cookie@<0.7.0": "0.7.0",
			"devalue@<5.6.4": "5.6.4",
			"picomatch@<2.3.2": "2.3.2",
			"picomatch@>=4.0.0 <4.0.4": "4.0.4",
			"anymatch>picomatch": "4.0.4"
		}
	}
}
